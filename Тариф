                .mpkg-tier-pill {
                    display: inline-flex;
                    align-items: center;
                    gap: 4px;
                    padding: 6px 11px;
                    border-radius: 999px;
                    border: 1.5px solid rgba(17,17,17,0.10);
                    background: rgba(255,255,255,0.82);
                    font-size: 12px;
                    font-weight: 600;
                    color: #3c3b39;
                    cursor: pointer;
                    transition: background 0.18s ease, border-color 0.18s ease, color 0.18s ease, transform 0.15s ease;
                    white-space: nowrap;
                    min-height: 34px;
