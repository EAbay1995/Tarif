<!doctype html>
<html lang="ru">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>BagaRetteu - Позиционная тарификация для Kaspi</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@500;700&display=swap"
            rel="stylesheet"
        />
        <style>
            :root {
                --bg-top: #f5e7d2;
                --bg-bottom: #fffaf2;
                --paper: rgba(255, 250, 242, 0.86);
                --paper-strong: #fffaf2;
                --card: #fffdf8;
                --ink: #111111;
                --muted: #62605b;
                --line: rgba(17, 17, 17, 0.09);
                --line-strong: rgba(17, 17, 17, 0.16);
                --night: #111b28;
                --night-soft: #1b2a3d;
                --accent: #ea6417;
                --accent-soft: rgba(234, 100, 23, 0.12);
                --sky: #153b56;
                --shadow: 0 24px 70px rgba(17, 17, 17, 0.08);
                --radius-xl: 36px;
                --radius-lg: 24px;
                --radius-md: 18px;
                --radius-sm: 14px;
            }

            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            html {
                scroll-behavior: smooth;
            }

            body {
                font-family: "IBM Plex Sans", sans-serif;
                color: var(--ink);
                background:
                    radial-gradient(
                        circle at 10% 0%,
                        rgba(234, 100, 23, 0.22),
                        transparent 24%
                    ),
                    radial-gradient(
                        circle at 90% 5%,
                        rgba(21, 59, 86, 0.18),
                        transparent 20%
                    ),
                    linear-gradient(
                        180deg,
                        var(--bg-top) 0%,
                        #fffdf8 32%,
                        var(--bg-bottom) 100%
                    );
            }

            body::before {
                content: "";
                position: fixed;
                inset: 0;
                pointer-events: none;
                background-image:
                    linear-gradient(
                        rgba(255, 255, 255, 0.18) 1px,
                        transparent 1px
                    ),
                    linear-gradient(
                        90deg,
                        rgba(255, 255, 255, 0.18) 1px,
                        transparent 1px
                    );
                background-size: 44px 44px;
                mask-image: linear-gradient(
                    180deg,
                    rgba(0, 0, 0, 0.24),
                    transparent 72%
                );
                opacity: 0.45;
            }

            img {
                max-width: 100%;
            }

            button,
            a,
            input {
                font: inherit;
            }

            a {
                color: inherit;
                text-decoration: none;
            }

            .hero-shell {
                padding: 22px 24px 72px;
            }

            .nav,
            .hero,
            .section,
            .footer-wrap {
                max-width: 1200px;
                margin: 0 auto;
            }

            .nav {
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 18px;
                padding: 18px 24px;
                border: 1px solid rgba(255, 255, 255, 0.42);
                border-radius: 28px;
                background: rgba(255, 250, 242, 0.76);
                backdrop-filter: blur(18px);
                box-shadow: 0 18px 60px rgba(17, 17, 17, 0.05);
                position: sticky;
                top: 18px;
                z-index: 10;
            }

            .brand {
                display: flex;
                align-items: center;
                gap: 10px;
                font-family: "Space Grotesk", sans-serif;
                font-size: 25px;
                font-weight: 700;
                letter-spacing: -0.05em;
            }

            .brand-mark {
                display: grid;
                place-items: center;
                width: 38px;
                height: 38px;
                border-radius: 12px;
                background: var(--night);
                color: #fff;
                font-size: 14px;
            }

            .brand span {
                color: var(--accent);
            }

            .nav-links {
                display: flex;
                align-items: center;
                gap: 24px;
                font-size: 14px;
                color: var(--muted);
            }

            .nav-links a {
                position: relative;
            }

            .nav-links a::after {
                content: "";
                position: absolute;
                left: 0;
                bottom: -5px;
                width: 100%;
                height: 1px;
                background: var(--ink);
                transform: scaleX(0);
                transform-origin: left;
                transition: transform 0.2s ease;
            }

            .nav-links a:hover::after {
                transform: scaleX(1);
            }

            .nav-cta,
            .btn {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                border-radius: 999px;
                border: 1px solid transparent;
                transition:
                    transform 0.18s ease,
                    background 0.18s ease,
                    border-color 0.18s ease,
                    color 0.18s ease;
            }

            .nav-cta {
                padding: 11px 18px;
                background: var(--night);
                color: #fff;
                font-size: 14px;
                font-weight: 600;
            }

            .nav-cta:hover,
            .btn:hover,
            .package-tier:hover,
            .builder-option:hover,
            .example-card:hover,
            .reason-card:hover,
            .package-card:hover,
            .rule-card:hover,
            .faq-item:hover {
                transform: translateY(-2px);
            }

            .hero {
                display: grid;
                grid-template-columns: minmax(0, 1.1fr) minmax(340px, 0.9fr);
                gap: 22px;
                margin-top: 26px;
                align-items: stretch;
            }

            .hero-copy,
            .hero-panel {
                animation: rise 0.72s ease both;
            }

            .hero-copy {
                position: relative;
                overflow: hidden;
                background: linear-gradient(
                    145deg,
                    var(--night) 0%,
                    #152130 50%,
                    #213246 100%
                );
                color: #fff;
                border-radius: var(--radius-xl);
                padding: clamp(34px, 5vw, 54px);
                box-shadow: 0 36px 90px rgba(17, 27, 40, 0.28);
            }

            .hero-copy::before,
            .hero-copy::after {
                content: "";
                position: absolute;
                border-radius: 999px;
                pointer-events: none;
            }

            .hero-copy::before {
                width: 300px;
                height: 300px;
                background: radial-gradient(
                    circle,
                    rgba(234, 100, 23, 0.36),
                    rgba(234, 100, 23, 0)
                );
                top: -120px;
                right: -70px;
            }

            .hero-copy::after {
                width: 260px;
                height: 260px;
                background: radial-gradient(
                    circle,
                    rgba(255, 255, 255, 0.08),
                    rgba(255, 255, 255, 0)
                );
                left: -80px;
                bottom: -100px;
            }

            .eyebrow {
                display: inline-flex;
                align-items: center;
                gap: 10px;
                padding: 8px 14px;
                border-radius: 999px;
                background: rgba(255, 255, 255, 0.09);
                border: 1px solid rgba(255, 255, 255, 0.14);
                font-size: 12px;
                font-weight: 600;
                letter-spacing: 0.08em;
                text-transform: uppercase;
                color: rgba(255, 255, 255, 0.82);
                margin-bottom: 24px;
            }

            .eyebrow::before {
                content: "";
                width: 8px;
                height: 8px;
                border-radius: 50%;
                background: var(--accent);
            }

            .hero-title,
            .section-title {
                font-family: "Space Grotesk", sans-serif;
                letter-spacing: -0.05em;
            }

            .hero-title {
                max-width: 11ch;
                font-size: clamp(40px, 7vw, 76px);
                line-height: 0.96;
                margin-bottom: 22px;
            }

            .hero-title span {
                color: #ffb676;
            }

            .hero-lead {
                max-width: 620px;
                font-size: 18px;
                line-height: 1.65;
                color: rgba(255, 255, 255, 0.78);
            }

            .hero-actions {
                display: flex;
                flex-wrap: wrap;
                gap: 12px;
                margin-top: 28px;
            }

            .btn {
                padding: 14px 22px;
                font-size: 15px;
                font-weight: 600;
            }

            .btn-primary {
                background: var(--accent);
                color: #fff;
                box-shadow: 0 16px 32px rgba(234, 100, 23, 0.24);
            }

            .btn-primary:hover {
                background: #f27a34;
            }

            .btn-secondary {
                background: rgba(255, 255, 255, 0.08);
                border-color: rgba(255, 255, 255, 0.18);
                color: #fff;
            }

            .hero-metrics {
                display: grid;
                grid-template-columns: repeat(3, minmax(0, 1fr));
                gap: 14px;
                margin-top: 34px;
            }

            .hero-metrics div {
                padding: 16px;
                border-radius: 18px;
                background: rgba(255, 255, 255, 0.07);
                border: 1px solid rgba(255, 255, 255, 0.12);
            }

            .hero-metrics strong {
                display: block;
                font-family: "Space Grotesk", sans-serif;
                font-size: 20px;
                letter-spacing: -0.04em;
                margin-bottom: 6px;
            }

            .hero-metrics span {
                font-size: 13px;
                line-height: 1.45;
                color: rgba(255, 255, 255, 0.72);
            }

            .hero-panel {
                display: grid;
                gap: 18px;
                animation-delay: 0.1s;
            }

            .spotlight-card {
                padding: 26px;
                border-radius: 30px;
                background: rgba(255, 250, 242, 0.86);
                border: 1px solid rgba(255, 255, 255, 0.44);
                box-shadow: var(--shadow);
                backdrop-filter: blur(14px);
            }

            .spotlight-card.warm {
                background: linear-gradient(
                    180deg,
                    rgba(255, 237, 218, 0.98),
                    rgba(255, 250, 242, 0.95)
                );
            }

            .spotlight-head {
                font-size: 13px;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.08em;
                color: var(--accent);
                margin-bottom: 12px;
            }

            .spotlight-card p {
                color: var(--muted);
                line-height: 1.65;
            }

            .spotlight-card strong {
                color: var(--ink);
            }

            .limit-steps {
                display: grid;
                gap: 12px;
                margin-top: 20px;
            }

            .limit-step {
                display: flex;
                gap: 14px;
                align-items: flex-start;
                padding: 14px 16px;
                border-radius: 18px;
                background: rgba(17, 17, 17, 0.04);
                border: 1px solid rgba(17, 17, 17, 0.05);
            }

            .limit-step span {
                min-width: 48px;
                padding: 8px 10px;
                border-radius: 999px;
                background: var(--night);
                color: #fff;
                font-size: 12px;
                font-weight: 700;
                text-align: center;
            }

            .limit-step p {
                font-size: 14px;
            }

            .combo-sample {
                display: grid;
                gap: 10px;
                margin: 18px 0 14px;
            }

            .sample-row {
                display: flex;
                justify-content: space-between;
                gap: 16px;
                padding: 14px 16px;
                border-radius: 18px;
                background: rgba(255, 255, 255, 0.56);
                border: 1px solid rgba(17, 17, 17, 0.06);
            }

            .sample-row span {
                color: var(--muted);
            }

            .sample-row strong {
                text-align: right;
            }

            .sample-row.total {
                background: var(--night);
            }

            .sample-row.total span,
            .sample-row.total strong {
                color: #fff;
            }

            .spotlight-foot {
                font-size: 14px;
            }

            .section {
                padding: 22px 24px 84px;
            }

            .section-top {
                display: grid;
                gap: 12px;
                max-width: 760px;
                margin-bottom: 34px;
            }

            .section-kicker {
                display: inline-flex;
                width: fit-content;
                align-items: center;
                gap: 10px;
                padding: 8px 14px;
                border-radius: 999px;
                background: rgba(234, 100, 23, 0.08);
                color: var(--accent);
                border: 1px solid rgba(234, 100, 23, 0.16);
                font-size: 12px;
                font-weight: 700;
                letter-spacing: 0.08em;
                text-transform: uppercase;
            }

            .section-title {
                font-size: clamp(32px, 4vw, 52px);
                line-height: 0.98;
            }

            .section-sub {
                font-size: 17px;
                line-height: 1.7;
                color: var(--muted);
            }

            .reason-grid {
                display: grid;
                grid-template-columns: repeat(4, minmax(0, 1fr));
                gap: 18px;
            }

            .reason-card,
            .package-card,
            .rule-card,
            .example-card,
            .builder-card,
            .calc-form,
            .calc-panel,
            .matrix-card,
            .faq-item,
            .logic-card {
                border-radius: 28px;
                border: 1px solid rgba(255, 255, 255, 0.54);
                background: rgba(255, 251, 244, 0.84);
                box-shadow: var(--shadow);
                backdrop-filter: blur(12px);
                transition:
                    transform 0.2s ease,
                    border-color 0.2s ease,
                    box-shadow 0.2s ease;
            }

            .reason-card {
                padding: 22px;
                min-height: 220px;
            }

            .reason-card.dark {
                background: linear-gradient(
                    165deg,
                    var(--night) 0%,
                    #203249 100%
                );
                color: #fff;
            }

            .reason-card.dark p,
            .reason-card.dark .reason-meta {
                color: rgba(255, 255, 255, 0.75);
            }

            .reason-label,
            .package-label,
            .rule-label,
            .example-label,
            .builder-eyebrow,
            .logic-label,
            .matrix-label {
                font-size: 12px;
                font-weight: 700;
                letter-spacing: 0.08em;
                text-transform: uppercase;
            }

            .reason-label,
            .package-label,
            .rule-label,
            .example-label,
            .builder-eyebrow,
            .logic-label {
                color: var(--accent);
                margin-bottom: 12px;
            }

            .reason-card.dark .reason-label {
                color: #ffb676;
            }

            .reason-card h3,
            .package-card h3,
            .rule-card h3,
            .example-card h3,
            .builder-card h3,
            .logic-card h3,
            .matrix-card h3 {
                font-family: "Space Grotesk", sans-serif;
                font-size: 28px;
                letter-spacing: -0.04em;
                line-height: 1.02;
                margin-bottom: 12px;
            }

            .reason-card p,
            .package-desc,
            .rule-card p,
            .example-card p,
            .builder-card p,
            .logic-card p,
            .matrix-card p {
                color: var(--muted);
                line-height: 1.62;
            }

            .reason-meta {
                margin-top: 18px;
                font-size: 13px;
                line-height: 1.5;
                color: #5d5d5d;
            }

            .logic-grid {
                display: grid;
                grid-template-columns: minmax(0, 1.06fr) minmax(320px, 0.94fr);
                gap: 18px;
            }

            .logic-main,
            .logic-side {
                display: grid;
                gap: 18px;
            }

            .logic-card {
                padding: 26px;
            }

            .logic-card.dark {
                background: linear-gradient(
                    160deg,
                    var(--night) 0%,
                    #203249 100%
                );
                color: #fff;
            }

            .logic-card.dark p,
            .logic-card.dark li,
            .logic-card.dark .formula-row span {
                color: rgba(255, 255, 255, 0.78);
            }

            .formula-board {
                display: grid;
                gap: 12px;
                margin-top: 20px;
            }

            .formula-row {
                display: flex;
                justify-content: space-between;
                gap: 16px;
                padding: 16px 18px;
                border-radius: 18px;
                background: rgba(17, 17, 17, 0.04);
                border: 1px solid rgba(17, 17, 17, 0.06);
            }

            .logic-card.dark .formula-row {
                background: rgba(255, 255, 255, 0.08);
                border-color: rgba(255, 255, 255, 0.1);
            }

            .formula-row strong {
                text-align: right;
            }

            .logic-list {
                display: grid;
                gap: 12px;
                margin-top: 18px;
                list-style: none;
            }

            .logic-list li {
                position: relative;
                padding-left: 18px;
                line-height: 1.6;
            }

            .logic-list li::before {
                content: "";
                position: absolute;
                top: 10px;
                left: 0;
                width: 8px;
                height: 8px;
                border-radius: 50%;
                background: var(--accent);
            }

            .logic-card.dark .logic-list li::before {
                background: #ffb676;
            }

            .note-badge {
                display: inline-flex;
                align-items: center;
                gap: 10px;
                padding: 10px 14px;
                border-radius: 999px;
                background: rgba(234, 100, 23, 0.1);
                color: var(--accent);
                font-size: 13px;
                font-weight: 600;
                margin-top: 18px;
            }

            .packages-note {
                display: flex;
                flex-wrap: wrap;
                gap: 10px;
                margin-bottom: 22px;
            }

            .packages-note span {
                padding: 10px 14px;
                border-radius: 999px;
                background: rgba(17, 17, 17, 0.05);
                border: 1px solid rgba(17, 17, 17, 0.06);
                font-size: 13px;
                color: var(--muted);
            }

            .packages-grid {
                display: grid;
                grid-template-columns: repeat(3, minmax(0, 1fr));
                gap: 18px;
            }

            .package-card {
                padding: 24px;
                position: relative;
                overflow: hidden;
            }

            .package-card::before {
                content: "";
                position: absolute;
                inset: 0;
                background: linear-gradient(
                    180deg,
                    var(--tone-soft),
                    transparent 45%
                );
                pointer-events: none;
            }

            .package-card > * {
                position: relative;
            }

            .package-card.turbo {
                --tone: #ea6417;
                --tone-soft: rgba(234, 100, 23, 0.12);
            }
            .package-card.fast {
                --tone: #d25834;
                --tone-soft: rgba(210, 88, 52, 0.12);
            }
            .package-card.express {
                --tone: #a64f27;
                --tone-soft: rgba(166, 79, 39, 0.12);
            }
            .package-card.standard {
                --tone: #164460;
                --tone-soft: rgba(22, 68, 96, 0.12);
            }
            .package-card.extended {
                --tone: #1e6a69;
                --tone-soft: rgba(30, 106, 105, 0.12);
            }
            .package-card.xml {
                --tone: #3c4d66;
                --tone-soft: rgba(60, 77, 102, 0.12);
            }

            .package-mark {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                min-width: 56px;
                height: 34px;
                padding: 0 12px;
                border-radius: 999px;
                background: var(--tone);
                color: #fff;
                font-size: 13px;
                font-weight: 700;
            }

            .package-top {
                display: flex;
                justify-content: space-between;
                gap: 12px;
                align-items: center;
                margin-bottom: 14px;
            }

            .package-price {
                display: flex;
                align-items: baseline;
                gap: 8px;
                margin-bottom: 10px;
                font-family: "Space Grotesk", sans-serif;
                font-size: 34px;
                font-weight: 700;
                letter-spacing: -0.05em;
            }

            .package-price span {
                font-size: 14px;
                font-family: "IBM Plex Sans", sans-serif;
                font-weight: 500;
                color: var(--muted);
            }

            .package-meta {
                display: flex;
                flex-wrap: wrap;
                gap: 8px;
                margin: 16px 0 18px;
            }

            .meta-chip,
            .speed-chip,
            .summary-chip {
                display: inline-flex;
                align-items: center;
                gap: 8px;
                padding: 8px 12px;
                border-radius: 999px;
                border: 1px solid rgba(17, 17, 17, 0.08);
                background: rgba(255, 255, 255, 0.74);
                font-size: 12px;
                font-weight: 600;
                color: #3c3b39;
            }

            .package-tiers {
                display: grid;
                gap: 10px;
                margin-bottom: 16px;
            }

            .package-tier {
                display: flex;
                justify-content: space-between;
                gap: 10px;
                padding: 13px 14px;
                border-radius: 16px;
                background: rgba(255, 255, 255, 0.72);
                border: 1px solid rgba(17, 17, 17, 0.08);
                transition:
                    transform 0.18s ease,
                    border-color 0.18s ease,
                    background 0.18s ease;
            }

            .package-tier strong {
                font-size: 14px;
            }

            .package-tier span {
                color: var(--muted);
                font-size: 13px;
            }

            .package-speed-title {
                font-size: 11px;
                font-weight: 700;
                letter-spacing: 0.08em;
                text-transform: uppercase;
                color: var(--muted);
                margin-bottom: 10px;
            }

            .speed-grid {
                display: flex;
                flex-wrap: wrap;
                gap: 8px;
            }

            .speed-chip.active {
                background: var(--tone-soft);
                border-color: transparent;
                color: var(--tone);
            }

            .rules-grid {
                display: grid;
                grid-template-columns: repeat(5, minmax(0, 1fr));
                gap: 16px;
                margin-bottom: 20px;
            }

            .rule-card {
                padding: 22px;
                min-height: 220px;
            }

            .matrix-grid {
                display: grid;
                gap: 12px;
            }

            .matrix-card {
                display: grid;
                grid-template-columns: 180px 150px minmax(0, 1fr);
                gap: 16px;
                align-items: center;
                padding: 18px 22px;
            }

            .matrix-label {
                color: var(--muted);
            }

            .matrix-main {
                font-family: "Space Grotesk", sans-serif;
                font-size: 24px;
                letter-spacing: -0.04em;
            }

            .matrix-max {
                font-size: 14px;
                font-weight: 700;
                color: var(--accent);
            }

            .calc-layout {
                display: grid;
                grid-template-columns: minmax(0, 0.98fr) minmax(320px, 1.02fr);
                gap: 18px;
            }

            .calc-form,
            .calc-panel {
                padding: 28px;
            }

            .calc-form {
                background: linear-gradient(
                    180deg,
                    rgba(255, 252, 247, 0.94),
                    rgba(255, 247, 237, 0.88)
                );
            }

            /* Fix 1: In-card result connector */
            .calc-inline-connector {
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: 0;
                margin: 20px 0 0;
            }

            .calc-inline-arrow {
                display: flex;
                align-items: center;
                gap: 10px;
                color: var(--accent);
                font-size: 20px;
                font-weight: 700;
                margin-bottom: 0;
                user-select: none;
            }

            .calc-inline-arrow::before,
            .calc-inline-arrow::after {
                content: "";
                flex: 1;
                height: 1px;
                background: var(--line-strong);
                min-width: 28px;
            }

            .calc-inline-divider {
                width: 100%;
                height: 1px;
                background: var(--line-strong);
                margin: 0;
            }

            .calc-inline-result {
                width: 100%;
                padding: 18px;
                border-radius: 20px;
                background: linear-gradient(135deg, rgba(234,100,23,0.07), rgba(234,100,23,0.03));
                border: 1.5px solid rgba(234,100,23,0.18);
                margin-top: 12px;
            }

            .calc-inline-result-kicker {
                font-size: 11px;
                font-weight: 700;
                letter-spacing: 0.08em;
                text-transform: uppercase;
                color: var(--accent);
                margin-bottom: 6px;
            }

            .calc-inline-result-number {
                font-family: "Space Grotesk", sans-serif;
                font-size: 38px;
                font-weight: 700;
                letter-spacing: -0.05em;
                line-height: 1;
                color: var(--ink);
                transition: color 0.18s ease;
            }

            .calc-inline-result-number.updated {
                color: var(--accent);
            }

            .calc-inline-result-unit {
                font-family: "IBM Plex Sans", sans-serif;
                font-size: 15px;
                font-weight: 500;
                color: var(--muted);
                margin-left: 4px;
            }

            .calc-inline-result-sub {
                margin-top: 8px;
                font-size: 13px;
                color: var(--muted);
                line-height: 1.5;
            }

            .calc-inline-result-sub strong {
                color: var(--ink);
            }

            @keyframes calc-highlight {
                0%   { color: var(--accent); }
                60%  { color: var(--accent); }
                100% { color: var(--ink); }
            }

            .calc-form h3,
            .calc-panel h3,
            .builder-head h3 {
                font-family: "Space Grotesk", sans-serif;
                font-size: 30px;
                letter-spacing: -0.04em;
                margin-bottom: 12px;
            }

            .calc-form p,
            .calc-panel p,
            .builder-head p,
            .builder-note,
            .summary-note,
            .footer-copy {
                color: var(--muted);
                line-height: 1.65;
            }

            .calc-fields {
                display: grid;
                gap: 14px;
                margin-top: 24px;
            }

            .calc-field label {
                display: block;
                margin-bottom: 8px;
                font-size: 13px;
                font-weight: 700;
                letter-spacing: 0.03em;
                color: #3d3a36;
            }

            .calc-field input {
                width: 100%;
                padding: 16px 18px;
                border-radius: 18px;
                border: 1px solid rgba(17, 17, 17, 0.11);
                background: rgba(255, 255, 255, 0.92);
                font-size: 24px;
                font-weight: 700;
                color: var(--ink);
                outline: none;
                transition:
                    border-color 0.18s ease,
                    box-shadow 0.18s ease;
            }

            .calc-field input:focus {
                border-color: rgba(234, 100, 23, 0.36);
                box-shadow: 0 0 0 4px rgba(234, 100, 23, 0.08);
            }

            .calc-hint {
                margin-top: 16px;
                padding: 14px 16px;
                border-radius: 18px;
                background: rgba(17, 17, 17, 0.05);
                font-size: 14px;
            }

            .calc-mobile-summary {
                display: none;
                gap: 12px;
                margin-top: 18px;
                padding: 18px;
                border-radius: 24px;
                background: linear-gradient(
                    165deg,
                    var(--night) 0%,
                    #23344b 100%
                );
                color: #fff;
                box-shadow: 0 24px 60px rgba(17, 27, 40, 0.18);
            }

            .calc-mobile-kicker {
                font-size: 11px;
                font-weight: 700;
                letter-spacing: 0.08em;
                text-transform: uppercase;
                color: rgba(255, 255, 255, 0.65);
            }

            .calc-mobile-big {
                display: flex;
                align-items: baseline;
                gap: 8px;
                font-family: "Space Grotesk", sans-serif;
                font-size: 42px;
                letter-spacing: -0.05em;
                line-height: 0.92;
            }

            .calc-mobile-big span {
                font-family: "IBM Plex Sans", sans-serif;
                font-size: 15px;
                color: rgba(255, 255, 255, 0.7);
            }

            .calc-mobile-grid {
                display: grid;
                gap: 10px;
            }

            .calc-mobile-item {
                padding: 14px;
                border-radius: 16px;
                background: rgba(255, 255, 255, 0.08);
                border: 1px solid rgba(255, 255, 255, 0.1);
            }

            .calc-mobile-item span {
                display: block;
                margin-bottom: 6px;
                font-size: 11px;
                font-weight: 700;
                letter-spacing: 0.08em;
                text-transform: uppercase;
                color: rgba(255, 255, 255, 0.62);
            }

            .calc-mobile-item strong {
                display: block;
                font-size: 16px;
                line-height: 1.35;
            }

            .calc-mobile-note {
                font-size: 13px;
                line-height: 1.6;
                color: rgba(255, 255, 255, 0.72);
            }

            .calc-panel {
                background: linear-gradient(
                    165deg,
                    var(--night) 0%,
                    #23344b 100%
                );
                color: #fff;
            }

            .calc-panel .section-kicker {
                background: rgba(255, 255, 255, 0.08);
                color: #ffb676;
                border-color: rgba(255, 255, 255, 0.14);
            }

            .calc-big {
                display: flex;
                align-items: baseline;
                gap: 10px;
                font-family: "Space Grotesk", sans-serif;
                font-size: clamp(58px, 8vw, 94px);
                line-height: 0.9;
                letter-spacing: -0.06em;
                margin: 10px 0 8px;
            }

            .calc-big span {
                font-size: 18px;
                font-family: "IBM Plex Sans", sans-serif;
                color: rgba(255, 255, 255, 0.7);
            }

            .calc-buckets {
                display: grid;
                gap: 12px;
                margin-top: 24px;
            }

            .calc-bucket {
                padding: 16px 18px;
                border-radius: 18px;
                background: rgba(255, 255, 255, 0.08);
                border: 1px solid rgba(255, 255, 255, 0.11);
            }

            .calc-bucket span {
                display: block;
                font-size: 12px;
                font-weight: 700;
                letter-spacing: 0.08em;
                text-transform: uppercase;
                color: rgba(255, 255, 255, 0.6);
                margin-bottom: 8px;
            }

            .calc-bucket strong {
                display: block;
                font-size: 20px;
                line-height: 1.3;
            }

            .calc-note {
                margin-top: 16px;
                font-size: 14px;
                color: rgba(255, 255, 255, 0.74);
            }

            .examples-grid {
                display: grid;
                grid-template-columns: repeat(3, minmax(0, 1fr));
                gap: 18px;
                margin-bottom: 22px;
            }

            .example-card {
                padding: 24px;
            }

            .example-lines {
                display: grid;
                gap: 10px;
                margin: 18px 0;
            }

            .example-line {
                display: flex;
                justify-content: space-between;
                gap: 12px;
                padding: 12px 14px;
                border-radius: 16px;
                background: rgba(17, 17, 17, 0.04);
                border: 1px solid rgba(17, 17, 17, 0.06);
            }

            .example-total {
                display: inline-flex;
                margin-top: 6px;
                padding: 10px 14px;
                border-radius: 999px;
                background: rgba(234, 100, 23, 0.1);
                color: var(--accent);
                font-size: 13px;
                font-weight: 700;
            }

            .builder-shell {
                display: grid;
                gap: 18px;
            }

            .builder-head {
                padding: 28px;
                border-radius: 30px;
                background: linear-gradient(
                    145deg,
                    rgba(17, 27, 40, 0.98),
                    rgba(33, 50, 70, 0.98)
                );
                color: #fff;
                box-shadow: 0 34px 80px rgba(17, 27, 40, 0.18);
            }

            .builder-head p {
                color: rgba(255, 255, 255, 0.72);
            }

            .builder-grid {
                display: grid;
                grid-template-columns: repeat(3, minmax(0, 1fr));
                gap: 18px;
            }

            .builder-card {
                padding: 24px;
                border-color: rgba(255, 255, 255, 0.48);
            }

            .builder-card.active {
                border-color: rgba(234, 100, 23, 0.34);
                box-shadow: 0 24px 70px rgba(234, 100, 23, 0.14);
            }

            .builder-top {
                display: flex;
                justify-content: space-between;
                gap: 12px;
                margin-bottom: 12px;
            }

            .builder-speed {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                padding: 8px 12px;
                border-radius: 999px;
                background: rgba(17, 17, 17, 0.05);
                color: #3a3a38;
                font-size: 12px;
                font-weight: 700;
            }

            .builder-tags {
                display: flex;
                flex-wrap: wrap;
                gap: 8px;
                margin: 16px 0;
            }

            .builder-options {
                display: grid;
                gap: 10px;
            }

            .builder-option {
                display: flex;
                justify-content: space-between;
                gap: 12px;
                width: 100%;
                padding: 14px 16px;
                border-radius: 16px;
                border: 1px solid rgba(17, 17, 17, 0.08);
                background: rgba(255, 255, 255, 0.76);
                cursor: pointer;
                transition:
                    transform 0.18s ease,
                    border-color 0.18s ease,
                    background 0.18s ease,
                    color 0.18s ease;
            }

            .builder-option strong {
                font-size: 14px;
                text-align: left;
            }

            .builder-option span {
                font-size: 13px;
                color: var(--muted);
                text-align: right;
            }

            .builder-option.selected {
                background: var(--night);
                border-color: var(--night);
            }

            .builder-option.selected strong,
            .builder-option.selected span {
                color: #fff;
            }

            .builder-summary {
                display: grid;
                grid-template-columns: minmax(0, 0.9fr) minmax(280px, 1.1fr);
                gap: 18px;
                padding: 26px 28px;
                border-radius: 30px;
                background: linear-gradient(
                    135deg,
                    rgba(255, 242, 227, 0.96),
                    rgba(255, 250, 242, 0.92)
                );
                border: 1px solid rgba(255, 255, 255, 0.56);
                box-shadow: var(--shadow);
            }

            .summary-title {
                font-size: 12px;
                font-weight: 700;
                letter-spacing: 0.08em;
                text-transform: uppercase;
                color: var(--muted);
                margin-bottom: 10px;
            }

            .summary-total {
                font-family: "Space Grotesk", sans-serif;
                font-size: clamp(40px, 5vw, 62px);
                letter-spacing: -0.05em;
                line-height: 0.9;
            }

            .summary-positions {
                margin-top: 10px;
                font-size: 16px;
                font-weight: 600;
            }

            .summary-chips {
                display: flex;
                flex-wrap: wrap;
                gap: 10px;
                margin-top: 12px;
            }

            .summary-chip.muted {
                color: var(--muted);
            }

            .summary-note {
                margin-top: 16px;
                font-size: 14px;
            }

            .builder-mobile-hint,
            .builder-mobile-dock,
            .builder-sheet-backdrop,
            .builder-sheet {
                display: none;
            }

            .builder-mobile-hint {
                align-items: center;
                gap: 10px;
                padding: 14px 16px;
                border-radius: 18px;
                background: rgba(17, 17, 17, 0.05);
                color: var(--muted);
                font-size: 13px;
                line-height: 1.5;
            }

            .builder-mobile-hint::before {
                content: "";
                width: 10px;
                height: 10px;
                border-radius: 50%;
                background: var(--accent);
                flex-shrink: 0;
            }

            .builder-mobile-dock {
                position: fixed;
                left: 0;
                right: 0;
                bottom: 0;
                padding: 0 16px calc(16px + env(safe-area-inset-bottom));
                z-index: 40;
                opacity: 0;
                transform: translateY(24px);
                pointer-events: none;
                transition:
                    opacity 0.22s ease,
                    transform 0.22s ease;
            }

            .builder-mobile-dock.active {
                opacity: 1;
                transform: translateY(0);
                pointer-events: auto;
            }

            .builder-mobile-trigger {
                width: 100%;
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 14px;
                padding: 16px 18px;
                border: none;
                border-radius: 22px;
                background: rgba(17, 27, 40, 0.98);
                color: #fff;
                box-shadow: 0 24px 60px rgba(17, 27, 40, 0.24);
                cursor: pointer;
            }

            .builder-mobile-copy {
                display: grid;
                gap: 4px;
                text-align: left;
            }

            .builder-mobile-label {
                font-size: 11px;
                font-weight: 700;
                letter-spacing: 0.08em;
                text-transform: uppercase;
                color: rgba(255, 255, 255, 0.62);
            }

            .builder-mobile-total {
                font-family: "Space Grotesk", sans-serif;
                font-size: 28px;
                letter-spacing: -0.05em;
                line-height: 0.95;
            }

            .builder-mobile-meta {
                font-size: 13px;
                line-height: 1.4;
                color: rgba(255, 255, 255, 0.76);
            }

            .builder-mobile-action {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                min-width: 92px;
                padding: 10px 14px;
                border-radius: 999px;
                background: rgba(255, 255, 255, 0.09);
                font-size: 12px;
                font-weight: 700;
                letter-spacing: 0.04em;
            }

            .builder-sheet-backdrop {
                position: fixed;
                inset: 0;
                background: rgba(17, 17, 17, 0.42);
                opacity: 0;
                pointer-events: none;
                transition: opacity 0.22s ease;
                z-index: 45;
            }

            .builder-sheet-backdrop.open {
                opacity: 1;
                pointer-events: auto;
            }

            .builder-sheet {
                position: fixed;
                left: 0;
                right: 0;
                bottom: 0;
                padding: 12px 12px calc(12px + env(safe-area-inset-bottom));
                opacity: 0;
                transform: translateY(100%);
                pointer-events: none;
                transition:
                    transform 0.26s ease,
                    opacity 0.26s ease;
                z-index: 46;
            }

            .builder-sheet.open {
                opacity: 1;
                transform: translateY(0);
                pointer-events: auto;
            }

            .builder-sheet-panel {
                max-height: min(78vh, 620px);
                overflow: auto;
                padding: 14px 14px 22px;
                border-radius: 28px 28px 22px 22px;
                background: linear-gradient(
                    180deg,
                    rgba(255, 249, 240, 0.98),
                    rgba(255, 253, 248, 0.98)
                );
                box-shadow: 0 30px 80px rgba(17, 17, 17, 0.18);
            }

            .builder-sheet-handle {
                width: 48px;
                height: 5px;
                margin: 0 auto 14px;
                border-radius: 999px;
                background: rgba(17, 17, 17, 0.16);
            }

            .builder-sheet-header {
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 12px;
                margin-bottom: 14px;
            }

            .builder-sheet-title {
                font-family: "Space Grotesk", sans-serif;
                font-size: 26px;
                letter-spacing: -0.04em;
            }

            .builder-sheet-close {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                min-width: 82px;
                padding: 10px 14px;
                border: 1px solid rgba(17, 17, 17, 0.08);
                border-radius: 999px;
                background: rgba(255, 255, 255, 0.85);
                color: var(--ink);
                font-size: 13px;
                font-weight: 700;
                cursor: pointer;
            }

            body.builder-sheet-open {
                overflow: hidden;
            }

            .faq-list {
                display: grid;
                gap: 14px;
            }

            .faq-item {
                overflow: hidden;
            }

            .faq-question {
                width: 100%;
                display: flex;
                justify-content: space-between;
                gap: 16px;
                align-items: center;
                padding: 22px 24px;
                background: transparent;
                border: none;
                cursor: pointer;
                text-align: left;
            }

            .faq-question strong {
                font-size: 20px;
                line-height: 1.2;
            }

            .faq-icon {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                width: 38px;
                height: 38px;
                flex-shrink: 0;
                border-radius: 50%;
                background: rgba(17, 17, 17, 0.05);
                font-size: 22px;
                transition:
                    transform 0.18s ease,
                    background 0.18s ease;
            }

            .faq-answer {
                display: none;
                padding: 0 24px 24px;
                color: var(--muted);
                line-height: 1.7;
            }

            .faq-item.open .faq-answer {
                display: block;
            }

            .faq-item.open .faq-icon {
                transform: rotate(45deg);
                background: rgba(234, 100, 23, 0.1);
            }

            footer {
                padding: 0 24px 26px;
            }

            .footer-wrap {
                display: flex;
                justify-content: space-between;
                gap: 14px;
                align-items: center;
                padding: 22px 26px;
                border-radius: 28px;
                background: rgba(17, 27, 40, 0.98);
                color: #fff;
                box-shadow: 0 28px 90px rgba(17, 27, 40, 0.2);
            }

            .footer-brand {
                font-family: "Space Grotesk", sans-serif;
                font-size: 24px;
                letter-spacing: -0.04em;
            }

            .footer-brand span {
                color: #ffb676;
            }

            @keyframes rise {
                from {
                    opacity: 0;
                    transform: translateY(24px);
                }
                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            @media (max-width: 1100px) {
                .reason-grid,
                .rules-grid,
                .packages-grid,
                .examples-grid,
                .builder-grid {
                    grid-template-columns: repeat(2, minmax(0, 1fr));
                }

                .hero,
                .logic-grid,
                .calc-layout,
                .builder-summary {
                    grid-template-columns: 1fr;
                }

                .matrix-card {
                    grid-template-columns: 1fr;
                }

                .hero-title {
                    max-width: 12ch;
                }
            }

            @media (max-width: 780px) {
                .desktop-only {
                    display: none !important;
                }

                .nav {
                    padding: 16px 18px;
                }

                .nav-links {
                    display: none;
                }

                .hero-shell,
                .section,
                footer {
                    padding-left: 16px;
                    padding-right: 16px;
                }

                .hero-copy,
                .spotlight-card,
                .reason-card,
                .logic-card,
                .package-card,
                .rule-card,
                .calc-form,
                .calc-panel,
                .example-card,
                .builder-card,
                .builder-head,
                .builder-summary,
                .faq-question,
                .faq-answer,
                .footer-wrap {
                    border-radius: 24px;
                }

                .hero-metrics,
                .reason-grid,
                .rules-grid,
                .packages-grid,
                .examples-grid,
                .builder-grid {
                    grid-template-columns: 1fr;
                }

                .hero-title {
                    font-size: 44px;
                }

                .hero-metrics {
                    gap: 10px;
                }

                .package-price {
                    font-size: 30px;
                }

                .summary-total,
                .calc-big {
                    font-size: 46px;
                }

                .footer-wrap {
                    flex-direction: column;
                    align-items: flex-start;
                }

                #builder {
                    padding-bottom: 154px;
                }

                .calc-mobile-summary,
                .builder-mobile-hint,
                .builder-mobile-dock,
                .builder-sheet-backdrop,
                .builder-sheet {
                    display: block;
                }

                .builder-mobile-hint {
                    display: flex;
                }
            }

            @media (max-width: 520px) {
                .hero-title,
                .section-title {
                    font-size: 36px;
                }

                .btn,
                .nav-cta {
                    width: 100%;
                }

                .hero-actions {
                    flex-direction: column;
                }

                .hero-metrics {
                    grid-template-columns: 1fr;
                }

                .sample-row,
                .formula-row,
                .example-line,
                .package-tier,
                .builder-option,
                .builder-top,
                .package-top {
                    flex-direction: column;
                    align-items: flex-start;
                }

                .sample-row strong,
                .formula-row strong,
                .example-line strong,
                .builder-option span {
                    text-align: left;
                }
            }

            /* =========================================================
               NEW MOBILE UX ELEMENTS  (hidden by default, shown on mobile)
               ========================================================= */

            /* Fix 1: Sticky calculator mini-summary bar */
            .calc-sticky-bar {
                display: none;
            }

            /* Fix 2: Step flow connector */
            .pricing-step-flow {
                display: none;
            }

            /* Fix 3: Multi-select hint banner */
            .packages-multiselect-hint {
                display: flex;
                align-items: flex-start;
                gap: 12px;
                padding: 14px 18px;
                border-radius: 18px;
                background: rgba(59, 130, 246, 0.07);
                border: 1px solid rgba(59, 130, 246, 0.18);
                color: #1e40af;
                font-size: 14px;
                line-height: 1.6;
                margin-bottom: 22px;
            }

            .packages-multiselect-hint::before {
                content: "💡";
                font-size: 16px;
                flex-shrink: 0;
                margin-top: 1px;
            }

            /* Fix 4: Recommended badge on package card */
            .package-recommended-badge {
                display: none;
                align-items: center;
                gap: 8px;
                padding: 8px 12px;
                border-radius: 999px;
                background: rgba(59, 130, 246, 0.1);
                border: 1px solid rgba(59, 130, 246, 0.22);
                color: #1d4ed8;
                font-size: 12px;
                font-weight: 700;
                margin-bottom: 12px;
            }

            .package-recommended-badge.visible {
                display: inline-flex;
            }

            /* Fix 5: Toast nudge */
            .mobile-selection-toast {
                display: none;
                position: fixed;
                bottom: 90px;
                left: 50%;
                transform: translateX(-50%) translateY(20px);
                z-index: 100;
                background: rgba(17, 27, 40, 0.96);
                color: #fff;
                font-size: 13px;
                line-height: 1.5;
                padding: 12px 18px;
                border-radius: 22px;
                box-shadow: 0 18px 50px rgba(17, 27, 40, 0.28);
                max-width: calc(100vw - 32px);
                text-align: center;
                opacity: 0;
                transition:
                    opacity 0.22s ease,
                    transform 0.22s ease;
                pointer-events: none;
                white-space: nowrap;
            }

            .mobile-selection-toast.show {
                opacity: 1;
                transform: translateX(-50%) translateY(0);
            }

            /* =========================================================
               MOBILE FIXES  (max-width: 640px)
               ========================================================= */
            @media (max-width: 640px) {
                body {
                    overflow-x: hidden;
                }

                /* --- Builder / package selector section --- */
                .builder-grid {
                    grid-template-columns: 1fr;
                }

                .builder-card {
                    padding: 18px;
                }

                .builder-top {
