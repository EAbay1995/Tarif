        <script>
            const volumePackages = [
                { label: "Стандарт 50", limit: 50, price: 4990 },
                { label: "Стандарт 100", limit: 100, price: 9990 },
                { label: "Стандарт 200", limit: 200, price: 14990 },
                { label: "Стандарт 300", limit: 300, price: 19990 },
                { label: "Расширенный 500", limit: 500, price: 9990 },
                { label: "Расширенный 1 000", limit: 1000, price: 14990 },
                { label: "Расширенный 2 000", limit: 2000, price: 24990 },
                { label: "XML 5 000", limit: 5000, price: 29990 },
                { label: "XML 10 000", limit: 10000, price: 39990 },
                { label: "XML безлимит", limit: Infinity, price: 49990 },
            ];

            const speedPackages = [
                { label: "Турбо 5", limit: 5, price: 4990 },
                { label: "Быстрый 10", limit: 10, price: 4990 },
                { label: "Экспресс 20", limit: 20, price: 4990 },
            ];

            const builderState = {};

            function setText(targets, value) {
                const ids = Array.isArray(targets) ? targets : [targets];
                ids.forEach((id) => {
                    const element = document.getElementById(id);
                    if (element) {
                        element.textContent = value;
                    }
                });
            }

            function renderSummaryChips(targets, selectedItems) {
                const ids = Array.isArray(targets) ? targets : [targets];

                ids.forEach((id) => {
                    const container = document.getElementById(id);
                    if (!container) {
                        return;
                    }

                    container.innerHTML = "";

                    if (!selectedItems.length) {
                        container.innerHTML =
                            '<span class="summary-chip muted">Пока ничего не выбрано</span>';
                        return;
                    }

                    selectedItems.forEach((item) => {
                        const chip = document.createElement("span");
                        chip.className = "summary-chip";
                        chip.textContent =
                            item.label + " · " + formatPrice(item.price);
                        container.appendChild(chip);
                    });
                });
            }

            function getPackageCountText(count) {
                const mod10 = count % 10;
                const mod100 = count % 100;

                if (mod10 === 1 && mod100 !== 11) {
                    return count + " пакет выбран";
                }
                if (mod10 >= 2 && mod10 <= 4 && (mod100 < 12 || mod100 > 14)) {
                    return count + " пакета выбрано";
                }
                return count + " пакетов выбрано";
            }

            function isMobileLayout() {
                return window.matchMedia("(max-width: 780px)").matches;
            }

            function closeBuilderSheet() {
                const trigger = document.getElementById(
                    "builder-mobile-trigger",
                );
                const sheet = document.getElementById("builder-sheet");
                const backdrop = document.getElementById(
                    "builder-sheet-backdrop",
                );

                document.body.classList.remove("builder-sheet-open");
                sheet.classList.remove("open");
                backdrop.classList.remove("open");
                sheet.setAttribute("aria-hidden", "true");
                trigger.setAttribute("aria-expanded", "false");
            }

            function openBuilderSheet() {
                if (!Object.keys(builderState).length || !isMobileLayout()) {
                    return;
                }

                const trigger = document.getElementById(
                    "builder-mobile-trigger",
                );
                const sheet = document.getElementById("builder-sheet");
                const backdrop = document.getElementById(
                    "builder-sheet-backdrop",
                );

                document.body.classList.add("builder-sheet-open");
                sheet.classList.add("open");
                backdrop.classList.add("open");
                sheet.setAttribute("aria-hidden", "false");
                trigger.setAttribute("aria-expanded", "true");
            }

            function syncBuilderSheetState() {
                if (!isMobileLayout()) {
                    closeBuilderSheet();
                }
            }

            function formatPrice(value) {
                return value.toLocaleString("ru-RU") + " ₸";
            }

            function formatCount(value) {
                return value.toLocaleString("ru-RU");
            }

            function clampNumber(value, fallback, minValue) {
                const parsed = parseInt(value, 10);
                if (Number.isNaN(parsed)) {
                    return fallback;
                }
                return Math.max(minValue, parsed);
            }

            function getVolumeRecommendation(positions) {
                return (
                    volumePackages.find((item) => positions <= item.limit) ||
                    volumePackages[volumePackages.length - 1]
                );
            }

            function getSpeedRecommendation(hotPositions) {
                if (hotPositions <= 0) {
                    return null;
                }
                if (hotPositions <= speedPackages[0].limit) {
                    return speedPackages[0];
                }
                if (hotPositions <= speedPackages[1].limit) {
                    return speedPackages[1];
                }
                if (hotPositions <= speedPackages[2].limit) {
                    return speedPackages[2];
                }
                return { overflow: true };
            }

            // Maps volume package label prefix to package card id suffix
            const volumeLabelToCardKey = {
                "Стандарт 50": "standard",
                "Стандарт 100": "standard",
                "Стандарт 200": "standard",
                "Стандарт 300": "standard",
                "Расширенный 500": "extended",
                "Расширенный 1 000": "extended",
                "Расширенный 2 000": "extended",
                "XML 5 000": "xml",
                "XML 10 000": "xml",
                "XML безлимит": "xml",
            };

            const speedLabelToCardKey = {
                "Турбо 5": "turbo",
                "Быстрый 10": "fast",
                "Экспресс 20": "express",
            };

            let lastCalcPositions = 0;

            function clearAllRecommendedBadges() {
                document.querySelectorAll(".package-recommended-badge").forEach(function(el) {
                    el.classList.remove("visible");
                    el.textContent = "";
                });
            }

            function setRecommendedBadge(cardKey, text) {
                var badge = document.getElementById("pkg-badge-" + cardKey);
                if (badge) {
                    badge.textContent = text;
                    badge.classList.add("visible");
                }
            }

            function updateStickyBar(positions) {
                var bar = document.getElementById("calc-sticky-bar");
                var posEl = document.getElementById("sticky-bar-positions");
                if (!bar || !posEl) return;
                posEl.textContent = "📍 У вас ~" + formatCount(positions) + " позиций";
                bar.classList.add("active");
            }

            function updateStepFlow(hasCalcValues, hasSelection) {
                var step1 = document.getElementById("step-1");
                var step2 = document.getElementById("step-2");
                var step3 = document.getElementById("step-3");
                if (!step1) return;

                if (hasCalcValues) {
                    step1.textContent = "✓ Посчитайте позиции";
                    step1.classList.add("done");
                    step1.classList.remove("active-step");
                } else {
                    step1.textContent = "1. Посчитайте позиции";
                    step1.classList.remove("done");
                    step1.classList.add("active-step");
                }

                if (hasSelection) {
                    step2.textContent = "✓ Выберите пакеты";
                    step2.classList.add("done");
                    step2.classList.remove("active-step");
                    step3.classList.add("active-step");
                } else {
                    step2.textContent = "2. Выберите пакеты";
                    step2.classList.remove("done");
                    if (hasCalcValues) {
                        step2.classList.add("active-step");
                    }
                }
            }

            function updateCalculator() {
                const products = clampNumber(
                    document.getElementById("calc-products").value,
                    100,
                    1,
                );
                const cities = clampNumber(
                    document.getElementById("calc-cities").value,
                    5,
                    1,
                );
                const hot = clampNumber(
                    document.getElementById("calc-hot").value,
                    5,
                    0,
                );
                const positions = products * cities;
                lastCalcPositions = positions;

                const volume = getVolumeRecommendation(positions);
                const speed = getSpeedRecommendation(hot);

                const volumeText = volume.label + " · " + formatPrice(volume.price);
                let speedText = "Скоростной пакет не требуется";
                let comboText = volumeText;
                let noteText =
                    "Пакеты округляются вверх до ближайшего тира. Если весь каталог помещается в скоростной пакет, можно начать только с него.";

                if (!speed) {
                    if (positions <= 20) {
                        noteText =
                            "Отличный вариант: все позиции легко войдут в скоростной пакет, если это подходит вашей модели продаж.";
                    }
                } else if (speed.overflow) {
                    speedText =
                        "Экспресс-20 — максимальный скоростной пакет, остальное — в объёмный";
                    comboText =
                        volume.label +
                        " + Экспресс 20 · от " +
                        formatPrice(volume.price + speedPackages[2].price);
                    noteText =
                        "Приоритетных позиций больше максимума Экспресс 20. Если приоритетных позиций больше 20, разбейте стратегию: топ попадает в Turbo / Fast / Express, остальное — в объёмный, Стандарт или XML.";
                } else {
                    speedText = speed.label + " · " + formatPrice(speed.price);

                    if (positions <= speed.limit) {
                        comboText = speed.label + " · " + formatPrice(speed.price);
                        noteText =
                            "Весь каталог помещается в скоростной пакет. Начните именно с него без покупки объёмного.";
                    } else {
                        comboText =
                            volume.label +
                            " + " +
                            speed.label +
                            " · " +
                            formatPrice(volume.price + speed.price);
                        noteText =
                            "Черновая рекомендация: объёмный пакет закрывает большинство позиций, а скоростный — приоритетные позиции. Пакеты суммируются, поэтому лимиты не конкурируют.";
                    }
                }

                setText(["calc-positions", "calc-mobile-positions"], formatCount(positions));
                setText(["calc-volume", "calc-mobile-volume"], volumeText);
                setText(["calc-speed", "calc-mobile-speed"], speedText);
                setText(["calc-combo", "calc-mobile-combo"], comboText);
                setText(["calc-note", "calc-mobile-note"], noteText);

                // Fix 1: Update inline result connector
                var inlineNum = document.getElementById("calc-inline-positions");
                var inlineSub = document.getElementById("calc-inline-sub");
                var inlineVolLabel = document.getElementById("calc-inline-volume-label");
                if (inlineNum) {
                    inlineNum.textContent = formatCount(positions);
                    inlineNum.style.animation = "none";
                    // Force reflow
                    void inlineNum.offsetWidth;
                    inlineNum.style.animation = "calc-highlight 0.9s ease forwards";
                }
                if (inlineVolLabel) {
                    inlineVolLabel.textContent = volume.label;
                }
                if (inlineSub) {
                    if (speed && !speed.overflow) {
                        inlineSub.innerHTML = "→ Подходит: <strong>" + volume.label + "</strong> + <strong>" + speed.label + "</strong>";
                    } else {
                        inlineSub.innerHTML = "→ Подходит: <strong>" + volume.label + "</strong>";
                    }
                }

                // Fix 1: Update sticky bar
                updateStickyBar(positions);

                // Fix 2: Update step flow
                updateStepFlow(true, Object.keys(builderState).length > 0);

                // Fix 4: Update recommended badges on package cards
                clearAllRecommendedBadges();
                const badgeText = "✓ Подходит вашим ~" + formatCount(positions) + " позициям";
                const volKey = volumeLabelToCardKey[volume.label];
                if (volKey) {
                    setRecommendedBadge(volKey, badgeText);
                }
                if (speed && !speed.overflow && speedLabelToCardKey[speed.label]) {
                    const speedKey = speedLabelToCardKey[speed.label];
                    // Don't duplicate if same card as volume (shouldn't happen but safety check)
                    if (speedKey !== volKey) {
                        setRecommendedBadge(speedKey, "✓ Скорость для ~" + formatCount(hot) + " топ-позиций");
                    }
                }
            }

            function updateBuilderSummary() {
                const selectedItems = Object.values(builderState);
                const dock = document.getElementById("builder-mobile-dock");

                if (!selectedItems.length) {
                    setText(["builder-total", "builder-sheet-total"], "-");
                    setText(
                        ["builder-positions", "builder-sheet-positions"],
                        "Выбери хотя бы один пакет, чтобы увидеть сумму и лимит активных позиций.",
                    );
                    setText(
                        ["builder-note", "builder-sheet-note"],
                        "Каждый тип пакета можно купить один раз. При этом можно набрать все 6 типов одновременно.",
                    );
                    renderSummaryChips(["builder-chips", "builder-sheet-chips"], []);
                    setText("builder-mobile-label", "Выберите пакеты");
                    setText("builder-mobile-total", "-");
                    setText("builder-mobile-meta", "Итог появится здесь сразу после выбора.");
                    setText("builder-mobile-action", "Развернуть");
                    dock.classList.remove("active");
                    closeBuilderSheet();
                    const payElEmpty = document.getElementById("builder-mobile-pay");
                    if (payElEmpty) payElEmpty.style.display = "none";
                    const namesElEmpty = document.getElementById("builder-mobile-names");
                    if (namesElEmpty) namesElEmpty.textContent = "";
                    updateStepFlow(lastCalcPositions > 0, false);
                    return;
                }

                const totalPrice = selectedItems.reduce(
                    (sum, item) => sum + item.price,
                    0,
                );
                const finitePositions = selectedItems.reduce(
                    (sum, item) => sum + (item.unlimited ? 0 : item.positions),
                    0,
                );
                const hasUnlimited = selectedItems.some(
                    (item) => item.unlimited,
                );

                let positionsText = "";
                let noteText = "";

                if (hasUnlimited && finitePositions > 0) {
                    positionsText =
                        "ХМЛ безлимит + " +
                        formatCount(finitePositions) +
                        " API-позиций";
                } else if (hasUnlimited) {
                    positionsText = "XML безлимит";
                } else {
                    positionsText =
                        formatCount(finitePositions) +
                        " активных позиций подключено";
                }

                if (selectedItems.length === 1) {
                    noteText = hasUnlimited
                        ? "XML — отдельный механизм. Фид обновляет цены раз в час и не зависит от API-лимитов Kaspi."
                        : "Этот пакет можно использовать самостоятельно, если весь каталог входит в его лимит активных позиций.";
                } else if (hasUnlimited) {
                    noteText =
                        "XML безлимит дополняет API-пакеты. Обновления через XML-фид не конкурируют себе и работают параллельно.";
                } else {
                    noteText =
                        "Пакеты суммируются. Например, Стандарт 200 + Турбо 5 = 205 активных позиций подключено.";
                }

                setText(["builder-total", "builder-sheet-total"], formatPrice(totalPrice));
                setText(["builder-positions", "builder-sheet-positions"], positionsText);
                setText(["builder-note", "builder-sheet-note"], noteText);
                renderSummaryChips(["builder-chips", "builder-sheet-chips"], selectedItems);

                setText("builder-mobile-label", getPackageCountText(selectedItems.length));
                setText("builder-mobile-total", formatPrice(totalPrice));
                setText("builder-mobile-meta", positionsText);
                setText("builder-mobile-action", "Смотреть сборку");
                dock.classList.add("active");

                // Fix 6: Show package names in dock and pay button
                const namesEl = document.getElementById("builder-mobile-names");
                const payEl = document.getElementById("builder-mobile-pay");
                if (namesEl) {
                    namesEl.textContent = selectedItems.map(function(i) { return i.label; }).join(" + ");
                }
                if (payEl) {
                    payEl.style.display = "inline-flex";
                    payEl.textContent = "Оплатить " + formatPrice(totalPrice);
                }

                // Fix 2: Update step flow
                updateStepFlow(lastCalcPositions > 0, true);
            }

            let toastTimer = null;

            function showSelectionToast(message) {
                if (!isMobileLayout()) return;
                const toast = document.getElementById("mobile-selection-toast");
                if (!toast) return;
                if (toastTimer) {
                    clearTimeout(toastTimer);
                    toast.classList.remove("show");
                }
                toast.textContent = message;
                // Force reflow to restart transition
                void toast.offsetWidth;
                toast.classList.add("show");
                toastTimer = setTimeout(function() {
                    toast.classList.remove("show");
                    toastTimer = null;
                }, 2500);
            }

            function handleBuilderSelection(button) {
                const packageKey = button.dataset.package;
                const card = document.getElementById("builder-" + packageKey);
                const isSelected = button.classList.contains("selected");

                document
                    .querySelectorAll(
                        '.builder-option[data-package="' + packageKey + '"]',
                    )
                    .forEach((item) => {
                        item.classList.remove("selected");
                    });

                if (isSelected) {
                    delete builderState[packageKey];
                    card.classList.remove("active");
                    updateBuilderSummary();
                    syncMobilePackagesList();
                    return;
                }

                button.classList.add("selected");
                builderState[packageKey] = {
                    label: button.dataset.label,
                    positions:
                        button.dataset.positions === "unlimited"
                            ? 0
                            : parseInt(button.dataset.positions, 10),
                    unlimited: button.dataset.positions === "unlimited",
                    price: parseInt(button.dataset.price, 10),
                };
                card.classList.add("active");
                updateBuilderSummary();
                syncMobilePackagesList();

                // Fix 5: Show toast nudge when a package is selected on mobile
                const speedKeys = ["turbo", "fast", "express"];
                const isSpeedPkg = speedKeys.indexOf(packageKey) !== -1;
                const selectedCount = Object.keys(builderState).length;
                if (selectedCount === 1 && !isSpeedPkg) {
                    showSelectionToast("Добавлено! Нужна скорость? Добавь Турбо, Быстрый или Экспресс ↓");
                } else if (selectedCount === 1 && isSpeedPkg) {
                    showSelectionToast("Добавлено! Нужен объём? Добавь Стандарт или Расширенный ↓");
                } else {
                    showSelectionToast("✓ " + button.dataset.label + " добавлен в сборку");
                }
            }

            function setupFaq() {
                document.querySelectorAll(".faq-question").forEach((button) => {
                    button.addEventListener("click", () => {
                        const item = button.closest(".faq-item");
                        const isOpen = item.classList.contains("open");
                        item.classList.toggle("open");
                        button.setAttribute("aria-expanded", String(!isOpen));
                    });
                });
            }

            function setupBuilder() {
                document
                    .querySelectorAll(".builder-option")
                    .forEach((button) => {
                        button.addEventListener("click", () =>
                            handleBuilderSelection(button),
                        );
                    });
            }

            function setupBuilderMobile() {
                document
                    .getElementById("builder-mobile-trigger")
                    .addEventListener("click", openBuilderSheet);
                document
                    .getElementById("builder-sheet-close")
                    .addEventListener("click", closeBuilderSheet);
                document
                    .getElementById("builder-sheet-backdrop")
                    .addEventListener("click", closeBuilderSheet);

                window.addEventListener("resize", syncBuilderSheetState);
                window.addEventListener("keydown", (event) => {
                    if (event.key === "Escape") {
                        closeBuilderSheet();
                    }
                });
            }

            function setupCalculator() {
                ["calc-products", "calc-cities", "calc-hot"].forEach((id) => {
                    document
                        .getElementById(id)
                        .addEventListener("input", updateCalculator);
                });
            }

            // Package metadata for chip colors and labels
            var mpkgMeta = {
                turbo:    { emoji: "⚡", name: "Турбо",      color: "#f97316" },
                fast:     { emoji: "🔥", name: "Быстрый",    color: "#ef4444" },
                express:  { emoji: "🚀", name: "Экспресс",   color: "#8b5cf6" },
                standard: { emoji: "📦", name: "Стандарт",   color: "#3b82f6" },
                extended: { emoji: "📊", name: "Расширенный", color: "#22c55e" },
                xml:      { emoji: "∞",  name: "XML",         color: "#6366f1" }
            };

            // Fix 2: Mobile package list sync
            function syncMobilePackagesList() {
                var packageKeys = ["turbo", "fast", "express", "standard", "extended", "xml"];
                var selectedCount = 0;
                packageKeys.forEach(function(key) {
                    if (builderState[key]) selectedCount++;
                });

                packageKeys.forEach(function(key) {
                    var row = document.getElementById("mpkg-" + key);
                    if (!row) return;
                    var isSelected = !!builderState[key];
                    var wasSelected = row.classList.contains("mpkg-selected");

                    if (isSelected) {
                        row.classList.add("mpkg-selected");
                    } else {
                        row.classList.remove("mpkg-selected");
                    }

                    // Update checkbox square: show checkmark text when selected
                    var checkbox = row.querySelector(".mpkg-checkbox");
                    if (checkbox) {
                        checkbox.textContent = isSelected ? "✓" : "";
                    }

                    // Sync tier pills
                    var pills = row.querySelectorAll(".mpkg-tier-pill");
                    pills.forEach(function(pill) {
                        if (isSelected && builderState[key] && builderState[key].label === pill.dataset.label) {
                            pill.classList.add("mpkg-tier-selected");
                        } else {
                            pill.classList.remove("mpkg-tier-selected");
                        }
                    });

                    // Update displayed price in row header for tier packages
                    var priceEl = document.getElementById("mpkg-price-" + key);
                    if (priceEl && isSelected) {
                        priceEl.textContent = formatPrice(builderState[key].price);
                    }
                });

                // Pulse unselected rows briefly when a new selection just happened
                var justSelected = null;
                packageKeys.forEach(function(key) {
                    var row = document.getElementById("mpkg-" + key);
                    if (row && builderState[key] && !row._wasSelected) {
                        justSelected = key;
                    }
                });
                // Track previous selection state for pulse logic
                packageKeys.forEach(function(key) {
                    var row = document.getElementById("mpkg-" + key);
                    if (row) row._wasSelected = !!builderState[key];
                });

                if (justSelected !== null) {
                    packageKeys.forEach(function(key) {
                        if (key === justSelected) return;
                        var row = document.getElementById("mpkg-" + key);
                        if (!row || builderState[key]) return;
                        row.classList.remove("mpkg-pulse");
                        // Force reflow to restart animation
                        void row.offsetWidth;
                        row.classList.add("mpkg-pulse");
                        setTimeout(function() { row.classList.remove("mpkg-pulse"); }, 350);
                    });
                }

                // Update counter
                var counterEl = document.getElementById("mpkg-list-counter");
                if (counterEl) {
                    counterEl.textContent = "Выбрано: " + selectedCount + " из 6";
                    if (selectedCount > 0) {
                        counterEl.classList.add("has-selection");
                    } else {
                        counterEl.classList.remove("has-selection");
                    }
                }

                // Update chip strip
                var chipsEl = document.getElementById("mobile-selection-chips");
                if (chipsEl) {
                    chipsEl.innerHTML = "";
                    var selectedKeys = packageKeys.filter(function(k) { return !!builderState[k]; });
                    if (selectedKeys.length === 0) {
                        var emptySpan = document.createElement("span");
                        emptySpan.className = "mpkg-chip-empty";
                        emptySpan.textContent = "Ничего не выбрано";
                        chipsEl.appendChild(emptySpan);
                    } else {
                        selectedKeys.forEach(function(key) {
                            var meta = mpkgMeta[key];
                            var state = builderState[key];
                            var chip = document.createElement("button");
                            chip.type = "button";
                            chip.className = "mpkg-sel-chip";
                            chip.style.setProperty("--chip-color", meta.color);
                            chip.dataset.deselect = key;
                            chip.innerHTML = meta.emoji + " " + state.label + " <span class='mpkg-sel-chip-x'>\u00D7</span>";
                            chipsEl.appendChild(chip);
                        });
                    }
                }
            }

            function setupMobilePackagesList() {
                var list = document.getElementById("mobile-packages-list");
                if (!list) return;
                list.addEventListener("click", function(e) {
                    var pill = e.target.closest(".mpkg-tier-pill");
                    if (!pill) return;
                    // Find the equivalent builder-option button in the desktop builder
                    var pkg = pill.dataset.package;
                    var label = pill.dataset.label;
                    var desktopBtn = document.querySelector(
                        '.builder-option[data-package="' + pkg + '"][data-label="' + label + '"]'
                    );
                    if (!desktopBtn) return;
                    // If this exact tier is already selected, deselect
                    var alreadySelected = builderState[pkg] && builderState[pkg].label === label;
                    if (alreadySelected) {
                        // Manually deselect: simulate toggle
                        desktopBtn.classList.add("selected");
                        handleBuilderSelection(desktopBtn);
                    } else {
                        // If a different tier of same package is selected, deselect it first via handleBuilderSelection logic
                        if (builderState[pkg]) {
                            // Mark current desktop btn as selected so handleBuilderSelection deselects it
                            var currentDesktopBtn = document.querySelector(
                                '.builder-option[data-package="' + pkg + '"][data-label="' + builderState[pkg].label + '"]'
                            );
                            if (currentDesktopBtn) {
                                currentDesktopBtn.classList.add("selected");
                                handleBuilderSelection(currentDesktopBtn);
                            }
                        }
                        // Now select new tier
                        handleBuilderSelection(desktopBtn);
                    }
                    syncMobilePackagesList();
                });
            }

            setupCalculator();
            setupBuilder();
            setupBuilderMobile();
            setupMobilePackagesList();
            setupFaq();
            updateCalculator();
            updateBuilderSummary();
            syncMobilePackagesList();
        </script>
    </body>
</html>
