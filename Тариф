                /* ---- Multi-select affordance: checkbox square ---- */
                .mpkg-checkbox {
                    width: 20px;
                    height: 20px;
                    border-radius: 4px;
                    border: 2px solid #ccc;
                    background: #fff;
                    flex-shrink: 0;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    font-size: 12px;
                    font-weight: 700;
                    color: #fff;
                    transition: background 0.18s ease, border-color 0.18s ease;
                    pointer-events: none;
