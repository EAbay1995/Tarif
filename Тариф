                .mpkg-row.mpkg-selected .mpkg-checkbox {
                    border-color: transparent;
                    background: var(--mpkg-color, var(--accent));
                }

                /* ---- Header above mobile list ---- */
                .mpkg-list-header {
                    display: flex;
                    flex-direction: column;
                    gap: 4px;
                    padding: 14px 16px 12px;
                    border-bottom: 1px solid rgba(17,17,17,0.07);
                    background: rgba(255,255,255,0.6);
                }

                .mpkg-list-header-title {
                    font-size: 14px;
                    font-weight: 700;
                    color: var(--ink);
                }

                .mpkg-list-header-hint {
                    font-size: 12px;
                    color: var(--muted);
                    display: flex;
                    align-items: center;
                    gap: 6px;
                }

                .mpkg-list-header-hint-box {
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    width: 14px;
                    height: 14px;
                    border-radius: 3px;
                    border: 2px solid #ccc;
                    flex-shrink: 0;
                }

                .mpkg-list-counter {
                    font-size: 12px;
                    font-weight: 700;
                    color: var(--muted);
                    transition: color 0.2s ease;
                }

                .mpkg-list-counter.has-selection {
                    color: var(--accent);
                }

                /* ---- Chip strip below mobile list ---- */
                #mobile-selection-chips {
                    display: flex;
                    flex-wrap: wrap;
                    gap: 8px;
                    padding: 12px 14px;
                    border-top: 1px solid rgba(17,17,17,0.07);
                    background: rgba(255,255,255,0.5);
                    min-height: 46px;
                    align-items: center;
                }

                .mpkg-chip-empty {
                    font-size: 12px;
                    color: var(--muted);
                }

                .mpkg-sel-chip {
                    display: inline-flex;
                    align-items: center;
                    gap: 5px;
                    padding: 5px 10px 5px 8px;
                    border-radius: 999px;
                    font-size: 12px;
                    font-weight: 600;
                    color: #fff;
                    background: var(--chip-color, var(--accent));
                    cursor: pointer;
                    border: none;
                    transition: opacity 0.15s ease, transform 0.15s ease;
                }

                .mpkg-sel-chip:hover {
                    opacity: 0.85;
                }

                .mpkg-sel-chip-x {
                    font-size: 13px;
                    line-height: 1;
                    opacity: 0.8;
                }

                /* ---- Row pulse animation on sibling select ---- */
                @keyframes mpkg-sibling-pulse {
                    0%   { transform: scale(1); }
                    40%  { transform: scale(1.01); box-shadow: 0 0 0 3px rgba(234,100,23,0.18); }
                    100% { transform: scale(1); box-shadow: none; }
                }

                .mpkg-row.mpkg-pulse {
                    animation: mpkg-sibling-pulse 0.28s ease forwards;
                }

                .mpkg-tier-pill.mpkg-tier-selected {
                    background: var(--mpkg-color, var(--accent));
                    border-color: transparent;
                    color: #fff;
                }

                /* Fix 1: calc inline result on mobile */
                .calc-inline-result-number {
                    font-size: 42px;
                }
            }
        </style>
    </head>
